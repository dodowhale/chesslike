{
  "name": "chesslike",
  "version": "0.0.0",
  "private": true,
  "description": "Pixel Chess Roguelike — 정통 체스와 로그라이크 모험이 결합된 픽셀 아트 게임",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "bun --filter @chesslike/client dev",
    "dev:server": "bun --filter @chesslike/server dev",
    "dev:all": "bun --filter '*' dev",
    "build": "bun --filter @chesslike/client build",
    "preview": "bun --filter @chesslike/client preview",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test",
    "gen:placeholders": "bun scripts/generate-piece-placeholders.ts",
    "gen:stockfish": "bun scripts/copy-stockfish.ts",
    "postinstall": "bun scripts/copy-stockfish.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
